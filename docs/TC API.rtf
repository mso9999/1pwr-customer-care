\f0\b\fs28 \cf0 \strokec2 POSTZero Customer Wallet Balance\
\pard\pardeftab720\partightenfactor0

\f1\b0\fs24 \cf0 \strokec2 https://SITE.sparkmeter.cloud/api/v0/customers/:customer_id/wallet/:wallet_type/zero-balance\
