# .gitignore
__pycache__/
*.pyc
*.pyo
node_modules/
.env
*.accdb
*.mdb
auth_info_baileys/
*.log
.DS_Store
.dropbox_cache/
firebase-service-account.json

# Local SSH keys (e.g. CC EC2). Copy EOver.pem into .secrets/ yourself — never commit keys.
.secrets/**
!.secrets/README.md
EOver.pem

# Pandoc-generated Word exports (open locally; do not commit)
docs/ops/*.docx

# LaTeX build artifacts (e.g. 1meter-1pdb-white-paper.tex)
docs/ops/*.aux
docs/ops/*.out
