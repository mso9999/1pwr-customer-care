# sandbox.env.example — environment for a ring-fenced CC sandbox instance.
#
# Strategy B: the SAME CC image/code as production, pointed at a SEPARATE
# sandbox database. Copy to deploy/sandbox.env (or .env.sandbox), fill in,
# and start a second CC process/container with these vars.
#
# 1) Create + migrate the sandbox DB (one command):
#        SANDBOX_DATABASE_URL=postgresql://cc_api@host:5432/onepower_cc_sandbox \
#          scripts/ops/init_sandbox_db.sh
# 2) Start CC with this env (note the non-prod port + DB):
#        set -a; . ./deploy/sandbox.env; set +a; python3 -m uvicorn ...
# 3) Point the app at it:
#        flutter run --dart-define=APP_ENV=sandbox \
#                    --dart-define=SANDBOX_API_BASE=http://<sandbox-host>:8101/api

# --- Database (ring-fence) ------------------------------------------------
# MUST be a sandbox database, NOT a production one. The seeder refuses to
# run against onepower_cc / onepower_bj / onepower_ls / onepower_zm unless
# APP_SANDBOX_ALLOW_PROD_DB=1 is also set.
DATABASE_URL=postgresql://cc_api@localhost:5432/onepower_cc_sandbox

# --- Sandbox flags --------------------------------------------------------
APP_SANDBOX=1
APP_ENV=sandbox

# Dummy account/meter the seeder creates. Override only if you want a
# different tag; keep it obviously non-production.
APP_SANDBOX_ACCOUNT=0000SBX
APP_SANDBOX_METER=SBX-TEST-0001
APP_SANDBOX_NAME=Sandbox Customer

# --- Serve on a non-prod port --------------------------------------------
CC_API_PORT=8101

# --- Country pack to serve (Benin or Lesotho config shape) ---------------
# BN = Benin, LS = Lesotho. The sandbox serves this country's app config.
COUNTRY=BN

# --- Optional: a separate Firebase project for sandbox push --------------
# Leave unset to disable FCM dispatch in the sandbox (best-effort no-op;
# notifications still get written to the app_notifications inbox).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sandbox-firebase-service-account.json

# --- Integrations NOT needed in sandbox (leave unset to disable) ----------
# KOIOS_*, THUNDERCLOUD_*, IOT_*, UGP_*, DROPBOX_*, SMS_GATEWAY_* are only
# required for live ingest / SMS gateway delivery. The app BFF (config,
# auth, dashboard, transactions, fees, notifications, care, direct
# messages, sandbox/seed) works without them.
