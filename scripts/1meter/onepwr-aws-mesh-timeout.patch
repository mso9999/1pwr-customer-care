  */
 #define configMQTT_AGENT_CONNACK_RECV_TIMEOUT_MS        ( CONFIG_GRI_MQTT_AGENT_CONNACK_RECV_TIMEOUT_MS )
 
+/**
+ * @brief Timeout for establishing the TLS socket connection.
+ * Defined in milliseconds.
+ */
+#define configMQTT_AGENT_TLS_CONNECT_TIMEOUT_MS         ( CONFIG_GRI_MQTT_AGENT_TLS_CONNECT_TIMEOUT_MS )
+
+/**
+ * @brief Timeout for TLS socket receive operations.
+ * Defined in milliseconds.
+ */
+#define configMQTT_AGENT_TLS_RECV_TIMEOUT_MS            ( CONFIG_GRI_MQTT_AGENT_TLS_RECV_TIMEOUT_MS )
+
+/**
+ * @brief Delay after WiFi/mesh connectivity before attempting MQTT/TLS reconnect.
+ * Defined in milliseconds.
+ */
+#define configMQTT_AGENT_MESH_RECONNECT_DELAY_MS        ( CONFIG_GRI_MQTT_AGENT_MESH_RECONNECT_DELAY_MS )
+
 /**
  * @brief The task stack size of the coreMQTT-Agent task.
